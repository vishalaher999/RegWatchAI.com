# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Anthropic (required for F2 summarisation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LangSmith (required for F5 audit tracing)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=regwatch-ai
LANGCHAIN_TRACING_V2=true

# Federal Register API (no key needed, but set base URL here for easy override)
FEDERAL_REGISTER_API_BASE=https://www.federalregister.gov/api/v1

# Database (SQLite for dev — swap to postgres:// for prod)
DATABASE_URL=sqlite:///./regwatch.db
